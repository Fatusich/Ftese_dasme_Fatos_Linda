<script>
  // Dust particle canvas
  (function() {
    const canvas = document.getElementById('dust');
    const ctx = canvas.getContext('2d');
    let W, H, particles = [];

    function resize() {
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    for (let i = 0; i < 55; i++) {
      particles.push({
        x: Math.random() * window.innerWidth,
        y: Math.random() * window.innerHeight,
        size: Math.random() * 1.5 + 0.5,
        speed: Math.random() * 0.4 + 0.15,
        opacity: Math.random() * 0.5 + 0.1,
        drift: (Math.random() - 0.5) * 0.3,
        phase: Math.random() * Math.PI * 2
      });
    }

    let frame = 0;
    function draw() {
      ctx.clearRect(0, 0, W, H);
      frame++;
      particles.forEach(p => {
        p.y -= p.speed;
        p.x += Math.sin(frame * 0.01 + p.phase) * 0.3 + p.drift;
        if (p.y < -10) {
          p.y = H + 10;
          p.x = Math.random() * W;
        }
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(184,150,90,${p.opacity * 0.6})`;
        ctx.fill();
      });
      requestAnimationFrame(draw);
    }
    draw();
  })();

  // Open animation
  function openInvitation() {
    const c = document.getElementById('envContainer');
    if (c.classList.contains('opened')) return;
    c.classList.add('opened');
    document.getElementById('tapHint').classList.add('hidden');
  }
</script>
