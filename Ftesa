<!DOCTYPE html>
<html lang="sq">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fatos & Linda — Ftesë Martese</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Great+Vibes&family=Cinzel:wght@300;400&family=Montserrat:wght@200;300;400&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --gold: #b8965a;
    --gold-light: #d4b47a;
    --gold-dark: #8a6c38;
    --cream: #faf6ef;
    --cream-dark: #f0e8d8;
    --parchment: #e8ddc8;
    --ink: #2a1f0e;
    --ink-mid: #5a4a30;
    --ink-light: #8a7a60;
  }

  html, body {
    width: 100%; height: 100%;
    background: #1a1410;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Cormorant Garamond', serif;
    overflow-x: hidden;
  }

  /* ── PARTICLE DUST ── */
  #dust { position: fixed; inset: 0; pointer-events: none; z-index: 0; }
  .mote {
    position: absolute;
    width: 2px; height: 2px;
    background: var(--gold-light);
    border-radius: 50%;
    opacity: 0;
    animation: float-up linear infinite;
  }
  @keyframes float-up {
    0%   { transform: translateY(0) translateX(0); opacity: 0; }
    10%  { opacity: 0.6; }
    90%  { opacity: 0.2; }
    100% { transform: translateY(-100vh) translateX(var(--dx)); opacity: 0; }
  }

  /* ── SCENE ── */
  .scene {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 40px 20px 60px;
    min-height: 100vh;
    justify-content: center;
  }

  /* ── ENVELOPE ── */
  .envelope-container {
    position: relative;
    width: 380px;
    cursor: pointer;
    user-select: none;
  }

  .envelope {
    position: relative;
    width: 380px;
    height: 248px;
    filter: drop-shadow(0 20px 60px rgba(0,0,0,0.7)) drop-shadow(0 0 30px rgba(184,150,90,0.15));
  }

  /* SVG envelope body */
  .env-svg { width: 100%; height: 100%; }

  /* Wax seal */
  .wax-seal {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 64px; height: 64px;
    z-index: 20;
    transition: transform 0.4s ease, opacity 0.4s ease;
  }
  .wax-seal circle { filter: drop-shadow(0 3px 8px rgba(0,0,0,0.5)); }

  .envelope-container.opened .wax-seal {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.5);
    pointer-events: none;
  }

  /* Flap */
  .env-flap-group {
    transform-origin: 190px 0px;
    transform-box: fill-box;
    transition: transform 1.1s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .envelope-container.opened .env-flap-group {
    transform: rotateX(-180deg);
  }

  /* ── CARD RISING ── */
  .card-rise {
    position: relative;
    width: 340px;
    max-height: 0;
    overflow: hidden;
    transition: max-height 1.4s cubic-bezier(0.16, 1, 0.3, 1);
    margin-top: -4px;
  }
  .envelope-container.opened ~ .card-rise {
    max-height: 1100px;
  }

  /* ── CARD ── */
  .card {
    background: var(--cream);
    width: 340px;
    border: 1px solid var(--parchment);
    position: relative;
    overflow: hidden;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 1s ease 0.8s, transform 1.2s cubic-bezier(0.16,1,0.3,1) 0.7s;
  }
  .envelope-container.opened ~ .card-rise .card {
    opacity: 1;
    transform: translateY(0);
  }

  /* Texture overlay */
  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(180,150,100,0.03) 3px, rgba(180,150,100,0.03) 4px),
      repeating-linear-gradient(90deg, transparent, transparent 3px, rgba(180,150,100,0.03) 3px, rgba(180,150,100,0.03) 4px);
    pointer-events: none;
    z-index: 0;
  }

  .card-inner { position: relative; z-index: 1; padding: 36px 32px 32px; text-align: center; }

  /* Corner ornaments */
  .ornament {
    position: absolute;
    width: 70px; height: 70px;
    opacity: 0.35;
  }
  .ornament.tl { top: 0; left: 0; }
  .ornament.tr { top: 0; right: 0; transform: scaleX(-1); }
  .ornament.bl { bottom: 0; left: 0; transform: scaleY(-1); }
  .ornament.br { bottom: 0; right: 0; transform: scale(-1,-1); }

  /* Gold rule */
  .rule {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 10px 0;
  }
  .rule-line { flex: 1; height: 0.5px; background: linear-gradient(90deg, transparent, var(--gold), transparent); }
  .rule-diamond {
    width: 5px; height: 5px;
    background: var(--gold);
    transform: rotate(45deg);
    flex-shrink: 0;
  }

  /* Couple illustration */
  .couple-wrap {
    margin: 12px auto 8px;
    display: flex;
    justify-content: center;
  }

  /* Names */
  .name-main {
    font-family: 'Great Vibes', cursive;
    font-size: 54px;
    color: var(--gold-dark);
    line-height: 1;
    display: block;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .name-main.n1 { transition-delay: 1.0s; }
  .name-main.n2 { transition-delay: 1.2s; }
  .envelope-container.opened ~ .card-rise .name-main { opacity: 1; transform: none; }

  .amp {
    font-family: 'Great Vibes', cursive;
    font-size: 28px;
    color: var(--gold-light);
    display: block;
    line-height: 1.2;
    opacity: 0;
    transition: opacity 0.8s ease 1.1s;
  }
  .envelope-container.opened ~ .card-rise .amp { opacity: 1; }

  /* Invitation text */
  .invite-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 14.5px;
    font-style: italic;
    color: var(--ink-mid);
    line-height: 1.8;
    margin: 10px 0;
    letter-spacing: 0.2px;
    opacity: 0;
    transition: opacity 0.8s ease 1.4s;
  }
  .envelope-container.opened ~ .card-rise .invite-text { opacity: 1; }

  /* Date block */
  .date-block {
    padding: 16px 0 12px;
    border-top: 0.5px solid var(--parchment);
    border-bottom: 0.5px solid var(--parchment);
    margin: 12px 0;
    opacity: 0;
    transition: opacity 0.8s ease 1.5s;
  }
  .envelope-container.opened ~ .card-rise .date-block { opacity: 1; }

  .date-month {
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 5px;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .date-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 64px;
    font-weight: 300;
    color: var(--ink);
    line-height: 1;
    letter-spacing: -2px;
  }
  .date-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 24px;
    margin-top: 8px;
  }
  .date-cell { text-align: center; }
  .date-cell-label {
    font-family: 'Cinzel', serif;
    font-size: 7px;
    letter-spacing: 3px;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 2px;
  }
  .date-cell-val {
    font-family: 'Cormorant Garamond', serif;
    font-size: 16px;
    color: var(--ink);
    font-style: italic;
  }
  .date-vline { width: 0.5px; height: 28px; background: var(--parchment); }

  /* Location button */
  .loc-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 10px auto 0;
    padding: 10px 22px;
    border: 0.5px solid var(--gold);
    border-radius: 2px;
    text-decoration: none;
    cursor: pointer;
    background: transparent;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s;
    opacity: 0;
    transition: opacity 0.8s ease 1.65s, color 0.3s, border-color 0.3s;
  }
  .envelope-container.opened ~ .card-rise .loc-btn { opacity: 1; }
  .loc-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
    z-index: 0;
  }
  .loc-btn:hover::before { transform: scaleX(1); }
  .loc-btn:hover .loc-text { color: var(--cream); }
  .loc-btn:hover .loc-icon path, .loc-btn:hover .loc-icon circle { stroke: var(--cream); }
  .loc-icon { position: relative; z-index: 1; flex-shrink: 0; }
  .loc-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 14px;
    font-style: italic;
    color: var(--gold);
    position: relative;
    z-index: 1;
    transition: color 0.4s;
    letter-spacing: 0.5px;
  }

  /* Closing */
  .closing-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 13.5px;
    font-style: italic;
    color: var(--ink-light);
    line-height: 1.7;
    margin: 12px 0 0;
    opacity: 0;
    transition: opacity 0.8s ease 1.75s;
  }
  .envelope-container.opened ~ .card-rise .closing-text { opacity: 1; }

  .sig {
    font-family: 'Great Vibes', cursive;
    font-size: 24px;
    color: var(--gold-dark);
    margin-top: 8px;
    opacity: 0;
    transition: opacity 0.8s ease 1.85s;
  }
  .envelope-container.opened ~ .card-rise .sig { opacity: 1; }

  .footer-dots {
    font-size: 10px;
    color: var(--gold);
    letter-spacing: 6px;
    margin-top: 6px;
    opacity: 0;
    transition: opacity 0.8s ease 1.95s;
  }
  .envelope-container.opened ~ .card-rise .footer-dots { opacity: 1; }

  /* Tap hint */
  .tap-hint {
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 4px;
    color: rgba(184,150,90,0.7);
    text-transform: uppercase;
    margin-top: 18px;
    animation: pulse-hint 2.5s ease-in-out infinite;
    transition: opacity 0.5s;
  }
  .tap-hint.hidden { opacity: 0; pointer-events: none; }
  @keyframes pulse-hint {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  /* Shimmer on envelope hover */
  .envelope-container:not(.opened):hover .env-body-path {
    filter: brightness(1.05);
  }

  /* ── SCROLL-IN stagger for card sections ── */
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
</head>
<body>

<!-- Dust particles -->
<canvas id="dust"></canvas>

<div class="scene">
  <!-- ENVELOPE -->
  <div class="envelope-container" id="envContainer" onclick="openInvitation()">
    <div class="envelope">
      <svg class="env-svg" viewBox="0 0 380 248" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="bodyGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#e8ddc8"/>
            <stop offset="100%" stop-color="#d4c8a8"/>
          </linearGradient>
          <linearGradient id="flapGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#ddd0b0"/>
            <stop offset="100%" stop-color="#c8bc98"/>
          </linearGradient>
          <linearGradient id="leftGrad" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#c0b490"/>
            <stop offset="100%" stop-color="#d4c8a8"/>
          </linearGradient>
          <linearGradient id="rightGrad" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#d4c8a8"/>
            <stop offset="100%" stop-color="#b8ac88"/>
          </linearGradient>
          <filter id="envShadow">
            <feDropShadow dx="0" dy="4" stdDeviation="12" flood-color="#000" flood-opacity="0.4"/>
          </filter>
        </defs>
        <!-- Body -->
        <rect x="0" y="0" width="380" height="248" rx="3" fill="url(#bodyGrad)" filter="url(#envShadow)" class="env-body-path"/>
        <!-- Left triangle -->
        <polygon points="0,0 0,248 190,140" fill="url(#leftGrad)" opacity="0.85"/>
        <!-- Right triangle -->
        <polygon points="380,0 380,248 190,140" fill="url(#rightGrad)" opacity="0.85"/>
        <!-- Bottom triangle -->
        <polygon points="0,248 380,248 190,140" fill="#c8bc98" opacity="0.9"/>
        <!-- Gold border -->
        <rect x="0.5" y="0.5" width="379" height="247" rx="2.5" fill="none" stroke="#b8965a" stroke-width="0.8" opacity="0.6"/>
        <!-- Inner border -->
        <rect x="10" y="10" width="360" height="228" rx="1" fill="none" stroke="#b8965a" stroke-width="0.4" opacity="0.4"/>
        <!-- Flap -->
        <g class="env-flap-group" id="envFlap">
          <polygon points="0,0 380,0 190,148" fill="url(#flapGrad)"/>
          <polygon points="0,0 380,0 190,148" fill="none" stroke="#b8965a" stroke-width="0.6" opacity="0.5"/>
        </g>
        <!-- Monogram on flap -->
        <text x="190" y="58" text-anchor="middle" font-family="'Great Vibes', cursive" font-size="28" fill="#9a7c4a" opacity="0.7">F &amp; L</text>
      </svg>
    </div>

    <!-- Wax Seal -->
    <svg class="wax-seal" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="32" cy="32" r="28" fill="#8B1A1A"/>
      <circle cx="32" cy="32" r="24" fill="#A02020"/>
      <circle cx="32" cy="32" r="21" fill="none" stroke="#c84040" stroke-width="0.8" opacity="0.5"/>
      <!-- Star points -->
      <polygon points="32,8 34,28 32,32 30,28" fill="#c84040" opacity="0.6"/>
      <polygon points="32,56 34,36 32,32 30,36" fill="#c84040" opacity="0.6"/>
      <polygon points="8,32 28,30 32,32 28,34" fill="#c84040" opacity="0.6"/>
      <polygon points="56,32 36,30 32,32 36,34" fill="#c84040" opacity="0.6"/>
      <polygon points="15,15 28,28 32,32 28,28" fill="#b83030" opacity="0.4"/>
      <polygon points="49,15 36,28 32,32 36,28" fill="#b83030" opacity="0.4"/>
      <polygon points="15,49 28,36 32,32 28,36" fill="#b83030" opacity="0.4"/>
      <polygon points="49,49 36,36 32,32 36,36" fill="#b83030" opacity="0.4"/>
      <!-- Monogram -->
      <text x="32" y="38" text-anchor="middle" font-family="'Great Vibes', cursive" font-size="18" fill="#f0d090">F&amp;L</text>
      <circle cx="32" cy="32" r="28" fill="none" stroke="#c87050" stroke-width="0.5" opacity="0.4"/>
    </svg>
  </div>

  <div class="tap-hint" id="tapHint">✦ &nbsp; Prekni për të hapur &nbsp; ✦</div>

  <!-- CARD -->
  <div class="card-rise" id="cardRise">
    <div class="card" id="weddingCard">

      <!-- Corner ornaments -->
      <svg class="ornament tl" viewBox="0 0 70 70" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 66 C4 4 4 4 66 4" stroke="#9a7c4a" stroke-width="1" fill="none"/>
        <path d="M4 50 C20 4 66 20 66 4" stroke="#9a7c4a" stroke-width="0.5" fill="none"/>
        <path d="M4 35 C4 4 35 4" stroke="#9a7c4a" stroke-width="0.4" fill="none" stroke-dasharray="2,3" opacity="0.5"/>
        <circle cx="4" cy="4" r="2" fill="#9a7c4a"/>
        <circle cx="4" cy="4" r="4" fill="none" stroke="#9a7c4a" stroke-width="0.5" opacity="0.5"/>
      </svg>
      <svg class="ornament tr" viewBox="0 0 70 70" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 66 C4 4 4 4 66 4" stroke="#9a7c4a" stroke-width="1" fill="none"/>
        <path d="M4 50 C20 4 66 20 66 4" stroke="#9a7c4a" stroke-width="0.5" fill="none"/>
        <path d="M4 35 C4 4 35 4" stroke="#9a7c4a" stroke-width="0.4" fill="none" stroke-dasharray="2,3" opacity="0.5"/>
        <circle cx="4" cy="4" r="2" fill="#9a7c4a"/>
        <circle cx="4" cy="4" r="4" fill="none" stroke="#9a7c4a" stroke-width="0.5" opacity="0.5"/>
      </svg>
      <svg class="ornament bl" viewBox="0 0 70 70" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 66 C4 4 4 4 66 4" stroke="#9a7c4a" stroke-width="1" fill="none"/>
        <path d="M4 50 C20 4 66 20 66 4" stroke="#9a7c4a" stroke-width="0.5" fill="none"/>
        <path d="M4 35 C4 4 35 4" stroke="#9a7c4a" stroke-width="0.4" fill="none" stroke-dasharray="2,3" opacity="0.5"/>
        <circle cx="4" cy="4" r="2" fill="#9a7c4a"/>
        <circle cx="4" cy="4" r="4" fill="none" stroke="#9a7c4a" stroke-width="0.5" opacity="0.5"/>
      </svg>
      <svg class="ornament br" viewBox="0 0 70 70" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 66 C4 4 4 4 66 4" stroke="#9a7c4a" stroke-width="1" fill="none"/>
        <path d="M4 50 C20 4 66 20 66 4" stroke="#9a7c4a" stroke-width="0.5" fill="none"/>
        <path d="M4 35 C4 4 35 4" stroke="#9a7c4a" stroke-width="0.4" fill="none" stroke-dasharray="2,3" opacity="0.5"/>
        <circle cx="4" cy="4" r="2" fill="#9a7c4a"/>
        <circle cx="4" cy="4" r="4" fill="none" stroke="#9a7c4a" stroke-width="0.5" opacity="0.5"/>
      </svg>

      <div class="card-inner">

        <!-- Top rule -->
        <div class="rule">
          <div class="rule-line"></div>
          <div class="rule-diamond"></div>
          <div class="rule-line"></div>
        </div>

        <!-- Couple Illustration -->
        <div class="couple-wrap">
          <svg width="200" height="190" viewBox="0 0 200 190" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="skinGroom" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#f5dcc8"/>
                <stop offset="100%" stop-color="#e8c8aa"/>
              </linearGradient>
              <linearGradient id="skinBride" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#fae8d8"/>
                <stop offset="100%" stop-color="#f0d4b8"/>
              </linearGradient>
              <linearGradient id="suitGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#2a2020"/>
                <stop offset="100%" stop-color="#1a1414"/>
              </linearGradient>
              <linearGradient id="dressGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#faf6ef"/>
                <stop offset="100%" stop-color="#f0e8d8"/>
              </linearGradient>
              <linearGradient id="hairBride" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#8B6040"/>
                <stop offset="100%" stop-color="#6B4820"/>
              </linearGradient>
              <linearGradient id="hairGroom" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#3a2810"/>
                <stop offset="100%" stop-color="#2a1808"/>
              </linearGradient>
            </defs>

            <!-- === GROOM (left side) === -->
            <!-- Shadow under feet -->
            <ellipse cx="72" cy="183" rx="28" ry="4" fill="#2a1f0e" opacity="0.15"/>

            <!-- Groom shoes -->
            <ellipse cx="62" cy="180" rx="10" ry="4" fill="#1a1010"/>
            <ellipse cx="80" cy="180" rx="9" ry="4" fill="#1a1010"/>

            <!-- Groom trousers -->
            <rect x="57" y="140" width="12" height="42" rx="2" fill="#222" />
            <rect x="71" y="140" width="12" height="42" rx="2" fill="#1c1c1c"/>

            <!-- Groom jacket body -->
            <path d="M52 95 Q50 100 50 115 L50 148 Q60 152 72 152 Q84 152 94 148 L94 115 Q94 100 92 95 Z" fill="url(#suitGrad)"/>
            <!-- Jacket lapels -->
            <path d="M72 95 L64 110 L72 118 L80 110 Z" fill="#3a3030"/>
            <path d="M64 110 L52 100 L52 108 L64 116 Z" fill="#2a2020"/>
            <path d="M80 110 L92 100 L92 108 L80 116 Z" fill="#242020"/>
            <!-- Shirt / bow tie -->
            <rect x="69" y="95" width="6" height="20" fill="#f5f0e8" rx="1"/>
            <path d="M67 100 Q72 103 77 100 Q72 107 67 104 Q72 101 77 104 Q72 107 67 100" fill="#8B1A1A" stroke="#8B1A1A" stroke-width="0.5"/>
            <!-- Boutonniere -->
            <circle cx="84" cy="108" r="3" fill="#e8c8a0" stroke="#c8a870" stroke-width="0.5"/>
            <circle cx="83" cy="106" r="1.5" fill="#d4b470"/>
            <!-- Jacket buttons -->
            <circle cx="72" cy="122" r="1" fill="#3a3030"/>
            <circle cx="72" cy="128" r="1" fill="#3a3030"/>
            <circle cx="72" cy="134" r="1" fill="#3a3030"/>
            <!-- Pocket square -->
            <path d="M86 110 L90 110 L89 115 L87 115 Z" fill="#f0d090" opacity="0.8"/>

            <!-- Groom arms -->
            <!-- Left arm -->
            <path d="M50 100 Q44 112 42 126 L46 128 Q48 116 54 104 Z" fill="url(#suitGrad)"/>
            <path d="M42 126 Q40 132 44 134" stroke="#f5dcc8" stroke-width="6" stroke-linecap="round" fill="none"/>
            <!-- Right arm (holding bride) -->
            <path d="M94 100 Q100 108 104 118 L108 116 Q104 106 98 98 Z" fill="url(#suitGrad)"/>

            <!-- Groom neck -->
            <rect x="68" y="80" width="8" height="18" rx="3" fill="url(#skinGroom)"/>
            <!-- Collar -->
